# =============================================================================
# geometry/2D_multi_grain_test.opts — wider channel: 5 isolated floor bumps
# + 6 ice grains (2 circular boundary + 4 circular trough grains).
#
# Generated by preprocess/build_geometry_multi_grain.py --Nx 304 --Ny 122 --P 2 --C 1:
#   Lx=1.0e-4, Ly=4.0e-5, 304x122 elements, uniform spacing.
#   h = 3.2895e-7 m uniformly (both x and y).
#   Floor: 5 bumps, R=0.4e-5, h=0.2e-5, evenly spaced (1.2e-5 m gaps between)
#   Same bump shape as the proven-stable 240x240 5-bump run (job64345061)
# -geom_file overrides -p/-C/-Nx/-Ny with degree (2,2)/C1.
#
# eps=3.68274e-07: re-derived 2026-06-17 via
#   python3 preprocess/comp_eps.py --Lx 1.0e-4 --Ly 4.0e-5 --dim 2 \
#       --Rave 3.5e-6 --T0 -20 --n 4
#   gave eps=4.6648e-07 (the full Kaempfer & Plapp 2009 thermodynamic upper
#   bound, eq 42a, safety factor 0.5) -- the project's previous 1.8659e-07
#   was this same eps manually shrunk by 2.5x while keeping the old 600x240
#   mesh; that combination was implicated in the eps_model75 HPC crash,
#   job64387928: DIVERGED_STEP_REJECTED after dt grew past ~1.3e3 s, because
#   eps_model=0.75*eps made the AC reaction term too stiff for the Newton
#   solve to stay within phase bounds at large dt.
#   On this 304x122 mesh, eps=4.6648e-07 rendered as ~9.5 elements across
#   the diffuse interface (1%-99% band) measured directly in ParaView --
#   above the ~7.5-element target, so rescaled down by 7.5/9.5:
#     eps = 4.6648e-07 * 7.5/9.5 = 3.68274e-07
#   Still well below comp_eps.py's 4.6648e-07 ceiling. Any eps below that
#   bound that keeps ~7.5+ elements across the band is fine -- the exact
#   value isn't load-bearing as long as both hold (see CLAUDE.md
#   "Phase-field interface parameter (eps)").
#
# Ice grains:
#   0: left boundary  (x=0,    cy=Ly/2), R=6e-6
#   1: right boundary (x=Lx,   cy=Ly/2), R=1.5e-5 (large Ostwald attractor)
#   2-5: trough grains at x=2.0e-5,4.0e-5,6.0e-5,8.0e-5 (midpoints between bumps),
#        cy=0 (half-circle on floor via zero-flux BC mirror), R=3.5e-6
# =============================================================================
# DOF_GRID: 610 124
-geom_file inputs/geometry/multi_grain/random_bumpy_floor_v1/mesh.dat
-p 2
-C 1
-ic_type multi_grains
-dim 2
-Lx 1.0e-4
-Ly 4.0e-5
-Lz 0
-sed_grain_x 1.0e-5,3.0e-5,5.0e-5,7.0e-5,9.0e-5
-sed_grain_R 0.4e-5,0.4e-5,0.4e-5,0.4e-5,0.4e-5
-sed_grain_h 0.2e-5,0.2e-5,0.2e-5,0.2e-5,0.2e-5
-ice_grain_cx 0.0,1.0e-4,2.0e-5,4.0e-5,6.0e-5,8.0e-5
-ice_grain_cy 2.0e-5,2.0e-5,0.0,0.0,0.0,0.0
-ice_grain_R  6.0e-6,1.5e-5,3.5e-6,3.5e-6,3.5e-6,3.5e-6
-ice_grain_ax 6.0e-6,1.5e-5,3.5e-6,3.5e-6,3.5e-6,3.5e-6
-ice_grain_ay 6.0e-6,1.5e-5,3.5e-6,3.5e-6,3.5e-6,3.5e-6
-delt_t 1.0e-4
-eps 3.68274e-07
-periodic 0
