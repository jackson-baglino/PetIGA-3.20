# =============================================================================
# experiment/Tgrad_T-20_G50_3d.opts — 3 days at -20 C, saturated, HORIZONTAL
# gradient |dT/dx| = 50 K/m (left warm -> right cold), TIME-SYNCHRONISED output.
# Pair with geometry/2D_two_grains_Tgrad.opts.
#
# See Tgrad_T-20_G0_3d.opts for the 3-day / synchronised-output rationale and
# Tgrad_T-20_G20.opts for the sign convention and BC handling.
#
# OBSERVED (90-day run, stopped early): the warm (left) grain fully sublimates
# and redeposits on the cold (right) grain by t = 0.52 d (total ice conserved).
# ~3.3x faster than G20, consistent with tau ~ 1/gradient. 3 days leaves the
# run in its settled single-grain end-state for most of the window.
#
# DRIVING dT: full domain 3.75e-2 K; between grain centres 1.25e-2 K.
# =============================================================================

-t_final 2.592e5                        # 3 days

-temp -20.0
-humidity 1.00
-grad_temp0 -50.0,0.0,0.0                # left warm -> right cold, |dT/dx| = 50 K/m

-flag_BC_Tfix 1                          # pin left/right walls; top/bottom insulating

-outp 0                                  # time-based output (overrides solver.opts -outp 1)
-n_out 100                               # 100 snapshots -> t_interv = t_final/99 ≈ 2618 s

-beta_sub0 5.9216e5                      # K&P beta0 at -20 C, alpha_c = 1.341e-2
-d0_sub0 1.0166e-9                        # physical capillary length at -20 C

-dtmax 5.7e2                             # 1.093 * tau_sub (tau_sub = 5.233e2 s)
-dtCFL 1
-dtCFL_dphimax 0.2
