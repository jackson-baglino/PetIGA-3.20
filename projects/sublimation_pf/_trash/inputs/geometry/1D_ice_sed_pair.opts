# =============================================================================
# geometry/1D_ice_sed_pair.opts — 1D: one pure ice grain + one pure sed grain
# Ice at x=Lx/4, sediment at x=3*Lx/4. Equal-sized grains.
# =============================================================================
-ic_type ice_sed_pair
-dim 1
-Nx 190
-Lx 1.25e-04
-RCice 1.875e-5
-RCsed 1.875e-5
-delt_t 1.0e-2
-eps 7.12e-07
