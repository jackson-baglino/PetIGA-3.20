# =============================================================================
# geometry/1D_ice_slab.opts — 1D centered ice slab + right-side sediment
# =============================================================================
-ic_type ice_slab
-dim 1
-Nx 152
-Lx 1.00e-04
-delt_t 1.0e-4
-eps 7.12e-07

# 1D problems are small enough for a direct LU solve (faster than GMRES+ILU).
-ksp_type preonly
-pc_type lu
