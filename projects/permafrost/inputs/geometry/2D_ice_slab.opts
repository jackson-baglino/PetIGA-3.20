# =============================================================================
# geometry/2D_ice_slab.opts — 2D: circular ice blob + right-side sediment slab
# Rectangular domain: thin in y, longer in x. Ice radius R = Ly.
# =============================================================================
-ic_type ice_slab
-dim 2
-Nx 304
-Ny 61
-Nz 1
-Lx 1.00e-04
-Ly 2.00e-05
-Lz 0
-delt_t 1.0e-4
-eps 4.6648e-07
