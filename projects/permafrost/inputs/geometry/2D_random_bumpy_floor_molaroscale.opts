-sed_grain_h 8.345219e-06,9.341324e-06,1.035555e-05,9.936823e-06,6.669881e-06,1.249919e-05,7.501620e-06,7.791265e-06,8.937428e-06,9.861880e-06,8.223967e-06,1.165791e-05,1.009856e-05,1.066459e-05,1.214553e-05,6.442765e-06,7.628839e-06,8.172579e-06,9.423189e-06,6.774976e-06,8.107223e-06,1.256230e-05,9.836288e-06,8.517814e-06
-ice_grain_cx 0.000000e+00,1.346700e-03,2.020050e-04,4.040100e-04,6.060150e-04,8.080200e-04,1.010025e-03,8.080200e-05,1.415627e-04,2.661387e-04,3.300283e-04,4.101388e-04,4.682062e-04,5.318152e-04,6.789785e-04,7.518242e-04,8.130937e-04,8.713728e-04,9.434684e-04,1.065185e-03,1.123494e-03,1.192019e-03
-ice_grain_cy 1.346700e-04,1.346700e-04,0.000000e+00,6.733500e-05,0.000000e+00,1.481370e-04,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00,0.000000e+00
-ice_grain_R  4.040100e-05,1.010025e-04,2.356725e-05,3.366750e-05,3.030075e-05,4.376775e-05,2.020050e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05
-ice_grain_ax 4.040100e-05,1.010025e-04,2.356725e-05,3.366750e-05,3.030075e-05,4.376775e-05,2.020050e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05
-ice_grain_ay 4.040100e-05,1.010025e-04,2.356725e-05,3.366750e-05,3.030075e-05,4.376775e-05,2.020050e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05,2.693400e-05,2.020050e-05,2.222055e-05,2.424060e-05
