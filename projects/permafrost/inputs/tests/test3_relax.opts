# ---------- Initial Condition ----------
-ic_type enclosed

# ---------- Domain ----------
-dim 2
-dof 4
-Nx 143
-Ny 285
-Nz 1
-Lx 1.25e-04
-Ly 2.5e-04
-Lz 0

# ---------- Element continuity ----------
-p 2
-C 1

# ---------- Grain Data ----------
-NCsed 2
-RCsed 0.175e-4
-RCsed_dev 0.55
-NCice 1
-RCice 0.375e-4
-RCice_dev 0.55

# ---------- Time Stepping & Output Frequency ----------
-delt_t 1.0e-4
-t_final 100000.0
-n_out 0
-outp 50
-Permafrost_output 1
-Permafrost_monitor 1

# ---------- Model Parameters ----------
-humidity 1.00
-temp -20.0
-grad_temp0 0.0,1.0e-03,0.0
-eps 9.3295e-07
-periodic 0
-nsteps_sed 0
-flag_BC_Tfix 0
-flag_BC_rhovfix 0
-flag_Tdep 0

# ---------- Initial Conditions ----------
-initial_cond ./inputs/tests/SthavisthaInputs/AssemblePhase_reinit.dat

## ---------- SNES ----------
-snes_type newtonls
-snes_max_it 10
-snes_rtol 1e-06
-snes_atol 1e-08
-snes_stol 1e-06
-snes_converged_reason

# ---------- Line search ----------
-snes_linesearch_type bt
-snes_linesearch_monitor

# ---------- KSP ----------
-ksp_type gmres
-ksp_rtol 1e-05
-ksp_atol 1e-08
-ksp_max_it 500
-ksp_gmres_restart 500
-ksp_converged_reason

# ---------- Preconditioner ----------
-pc_type bjacobi
-sub_pc_type ilu
-sub_pc_factor_levels 1
