# =============================================================================
# test5_SlabAndGrains.opts — 2D ice slab with random grain region
#
# Purpose: Study ice migration driven by sublimation from a solid ice slab
#          into a region of randomly-packed ice and sediment grains. The slab
#          occupies the rightmost x_slab_frac fraction of the domain; grains
#          fill the left region.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test5_SlabAndGrains.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type slab_and_grains                # ice slab on right, random grains on left

# ---------- Domain ----------
-dim 2
-Nx 379
-Ny 190
-Nz 1
-Lx 2.5e-4                             # domain length in x (m)
-Ly 1.25e-4                            # domain length in y (m)
-Lz 0

# ---------- Grain Distribution ----------
-NCice 15                               # number of ice grains in grain region
-NCsed 12                               # number of sediment grains in grain region
-RCice 1.0e-5                           # mean ice grain radius (m)
-RCsed 1.3e-5                           # mean sediment grain radius (m); > RCice
-RCice_dev 0.15                         # ice radius polydispersity (fractional std dev)
-RCsed_dev 0.15                         # sediment radius polydispersity (fractional std dev)
-x_slab_frac 0.175                      # fraction of Lx occupied by the right-side ice slab

# ---------- Time Stepping ----------
-delt_t 1.0e-2                          # initial time step (s)
-t_final 1814400.0                      # total simulation time (s) — 21 days

# ---------- Phase-Field Physics ----------
-eps 3.5e-7                             # diffuse interface half-width (m)
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0

# ---------- Time Stepping Override ----------
-NRmax 8                                # raised from 5 to tolerate stiff transients
