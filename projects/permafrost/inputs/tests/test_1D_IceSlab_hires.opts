# =============================================================================
# test_1D_IceSlab_hires.opts — 1D centered ice slab, high resolution
#
# Purpose: Same as test_1D_IceSlab.opts but with eps=3.56e-07 m and mesh
#          sized at 2× standard resolution (Nx=304).
#          Use for convergence studies or high-fidelity 1D benchmarks.
#          See test_1D_IceSlab.opts for the standard-resolution version.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_1D_IceSlab_hires.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type ice_slab                       # centered ice slab with right-side sediment

# ---------- Domain ----------
-dim 1
-Nx 304
-Lx 1.00e-04                            # domain length in x (m)

# ---------- Time Stepping ----------
-delt_t 1.0e-4                          # initial time step (s)
-t_final 864000.0                       # total simulation time (s) — 10 days

# ---------- Phase-Field Physics ----------
-eps 3.56e-07                           # diffuse interface half-width (m); 4 elements/interface
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0

# ---------- Linear solver override (1D: direct LU) ----------
-ksp_type preonly                       # single application of the PC
-pc_type lu                             # direct sparse LU
