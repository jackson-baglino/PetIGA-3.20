# =============================================================================
# test_1D_SeparatedGrainPair.opts — 1D cross-section of separated ice-grain pair
#
# Purpose: 1D cross-section of the 2D separated grain pair, taken along a
#          vertical line through x = 0.5*Lx_2D. Two concentric ice-shell /
#          sediment-core pairs with a 5 µm air gap between outer ice surfaces
#          (grain_sep = 5.0e-6; ~7 interface widths). Standard resolution.
#          Domain length Lx = Ly of the 2D test; mesh Nx = Ny of the 2D test.
#          See test_2D_SeparatedGrainPair.opts for the 2D version.
#          See test_1D_TouchingGrainPair.opts for the touching variant.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_1D_SeparatedGrainPair.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type enclosed                       # 1D enclosed grain pair IC

# ---------- Domain ----------
-dim 1
-Nx 190                                 # matches Ny of the 2D test (test_2D_SeparatedGrainPair)
-Lx 1.25e-04                            # matches Ly of the 2D test (m)

# ---------- Grain Radii ----------
-RCice 1.875e-5                         # ice shell outer radius — both grains (m)
-RCsed 8.75e-6                          # sediment core radius — both grains (m)
-grain_sep 5.0e-6                       # air gap between outer ice surfaces (m); ~7 interface widths

# Per-grain overrides (uncomment to create asymmetric grains):
# -RCice0 1.2e-5                        # outer ice radius of grain 0 (default: RCice)
# -RCice1 2.5e-5                        # outer ice radius of grain 1 (default: RCice)
# -RCsed0 6.0e-6                        # sediment core radius of grain 0 (default: RCsed)
# -RCsed1 6.0e-6                        # sediment core radius of grain 1 (default: RCsed)

# ---------- Time Stepping ----------
-delt_t 1.0e-2                          # initial time step (s)
-t_final 86400.0                        # total simulation time (s) — 1 day

# ---------- Phase-Field Physics ----------
-eps 7.12e-07                           # diffuse interface half-width (m)
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0

# ---------- Time Stepping Override ----------
-NRmax 8                                # raised from 5 to tolerate stiff transients
