# =============================================================================
# T17: Temperature Dirichlet BC fix (flag_BC_Tfix = 1)
# Flat interface IC (flag_tIC=2), grad_temp=1e4 K/m (ΔT=1K), hum=1.0.
# BCs pin T at left (-20.5°C) and right (-19.5°C) boundaries.
# No sublimation/deposition (at saturation) → temperature stays near T0.
# Expected: domain-avg temperature remains within ±0.5°C of -20°C.
# =============================================================================
-dim 1
-dof 4
-Nx 152
-Lx 1.00e-04
-p 2
-C 1
-delt_t 1.0e-4
-t_final 1.0e-2
-n_out 0
-outp 1
-Permafrost_output 1
-Permafrost_monitor 1
-humidity 1.0
-temp -20.0
-grad_temp0 1.0e4,0.0,0.0
-eps 9.3295e-07
-periodic 0
-flag_tIC 2
-flag_BC_Tfix 1
-flag_BC_rhovfix 0
-flag_Tdep 0
-nsteps_sed 10
-flag_sed_mode 1
-snes_type newtonls
-snes_max_it 10
-snes_rtol 1e-06
-snes_atol 1e-08
-snes_stol 1e-06
-snes_converged_reason
-snes_linesearch_type bt
-ksp_type gmres
-ksp_rtol 1e-05
-ksp_atol 1e-08
-ksp_max_it 500
-ksp_gmres_restart 500
-pc_type bjacobi
-sub_pc_type ilu
-sub_pc_factor_levels 1
