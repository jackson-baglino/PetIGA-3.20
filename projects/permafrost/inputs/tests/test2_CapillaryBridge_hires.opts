# =============================================================================
# test2_CapillaryBridge_hires.opts — 2D capillary ice bridge, high resolution
#
# Purpose: Same as test2_CapillaryBridge.opts but with eps=3.56e-07 m and
#          mesh sized for 4 elements across the diffuse interface (Nx=497, Ny=994).
#          See test2_CapillaryBridge.opts for the standard-resolution version.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test2_CapillaryBridge_hires.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type capillary                      # capillary ice bridge between sediment grains

# ---------- Domain ----------
-dim 2
-Nx 497
-Ny 994
-Nz 1
-Lx 1.25e-04                            # domain length in x (m)
-Ly 2.5e-04                             # domain length in y (m)
-Lz 0

# ---------- Grain Data ----------
-NCsed 2                                # number of sediment grains
-RCsed 0.175e-4                         # mean sediment grain radius (m)
-RCsed_dev 0.55                         # sediment radius polydispersity (fractional std dev)
-NCice 1                                # number of ice grains
-RCice 0.375e-4                         # mean ice grain radius (m)
-RCice_dev 0.55                         # ice radius polydispersity (fractional std dev)

# ---------- Time Stepping ----------
-delt_t 1.0e-4                          # initial time step (s)
-t_final 1.0                            # total simulation time (s)

# ---------- Phase-Field Physics ----------
-eps 3.56e-07                           # diffuse interface half-width (m); 4 elements/interface
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion
-flag_sed_mode 1                        # sediment: freeze at t_sed_freeze (from universal)

# ---------- Thermal & Humidity ----------
-humidity 1.00
-temp -20.0
-grad_temp0 0.0,1.0e-03,0.0            # vertical temperature gradient (K/m)

# ---------- Initial Condition File ----------
-initial_cond ./inputs/tests/SthavisthaInputs/AssemblePhase_reinit.dat
