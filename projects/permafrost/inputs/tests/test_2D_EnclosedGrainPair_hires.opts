# =============================================================================
# test_2D_EnclosedGrainPair_hires.opts — 2D enclosed grain pair, high resolution
#
# Purpose: Same geometry as test_2D_EnclosedGrainPair.opts but with eps=3.56e-07 m
#          and mesh sized for 4 elements across the diffuse interface (Nx=249, Ny=497).
#          See test_2D_EnclosedGrainPair.opts for the standard-resolution version.
#          See test_1D_EnclosedGrainPair_hires.opts for the 1D hi-res cross-section.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_2D_EnclosedGrainPair_hires.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type enclosed                       # ice grain enclosing two sediment grains

# ---------- Domain ----------
-dim 2
-Nx 249
-Ny 497
-Nz 1
-Lx 6.25e-05                            # domain length in x (m)
-Ly 1.25e-04                            # domain length in y (m)
-Lz 0

# ---------- Grain Radii ----------
-RCice 1.875e-5                         # ice shell outer radius — both grains (m)
-RCsed 8.75e-6                          # sediment core radius — both grains (m)

# Per-grain overrides (uncomment to create asymmetric grains):
# -RCice0 1.2e-5                        # outer ice radius of grain 0 (m)
# -RCice1 2.5e-5                        # outer ice radius of grain 1 (m)
# -RCsed0 6.0e-6                        # sediment core radius of grain 0 (m)
# -RCsed1 6.0e-6                        # sediment core radius of grain 1 (m)
# -grain_sep 5.0e-6                     # air gap between outer ice surfaces; 0 = tangent

# ---------- Time Stepping ----------
-delt_t 1.0e-2                          # initial time step (s)
-t_final 1814400.0                      # total simulation time (s) — 21 days

# ---------- Phase-Field Physics ----------
-eps 3.56e-07                           # diffuse interface half-width (m); 4 elements/interface
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 1.00
-temp -20.0
-grad_temp0 0.0,0.0,0.0

# ---------- Time Stepping Override ----------
-NRmax 8                                # raised from 5 to tolerate stiff transients
