# =============================================================================
# test_2D_SingleIceGrain.opts — 2D single pure ice grain, domain-centred
#
# Purpose: Minimal test of a single circular ice grain in 2D air with no
#          sediment. The grain is centred at (Lx/2, Ly/2). Square domain:
#          Lx = Ly = 4 × RCice, giving wall padding = RCice (~14 elements).
#          See test_1D_SingleIceGrain.opts for the 1D cross-section.
#          See test_2D_IceSedPair.opts for the ice+sediment variant.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_2D_SingleIceGrain.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type single_ice                     # single ice grain centred in domain

# ---------- Domain ----------
-dim 2
-Nx 96                                  # standard resolution: dx ≈ 6.51e-7 m ≈ 0.91 eps
-Ny 96
-Nz 1
-Lx 6.25e-05                            # domain length in x (m); 4 × RCice
-Ly 6.25e-05                            # domain length in y (m); square domain
-Lz 0

# ---------- Grain Radius ----------
-RCice 1.875e-5                         # ice grain radius (m); padding = RCice from each wall

# ---------- Time Stepping ----------
-delt_t 1.0e-2                          # initial time step (s)
-t_final 86400.0                        # total simulation time (s) — 1 day

# ---------- Phase-Field Physics ----------
-eps 7.12e-07                           # diffuse interface half-width (m)
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0

# ---------- Time Stepping Override ----------
-NRmax 8
