# =============================================================================
# T03: Sediment inertness (mob_sed = 0)
# 50 steps.  The sediment slab (right of ice, centred at 0.75*Lx) must not
# change volume when mob_sed = 0.
# =============================================================================
-dim 1
-dof 4
-Nx 152
-Lx 1.00e-04
-p 2
-C 1
-delt_t 1.0e-4
-t_final 5.0e-3
-n_out 0
-outp 1
-Permafrost_output 1
-Permafrost_monitor 1
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0
-eps 9.3295e-07
-periodic 0
-flag_tIC 0
-flag_BC_Tfix 0
-flag_BC_rhovfix 0
-flag_Tdep 0
-mob_sed 0.0
-snes_type newtonls
-snes_max_it 10
-snes_rtol 1e-06
-snes_atol 1e-08
-snes_stol 1e-06
-snes_converged_reason
-snes_linesearch_type bt
-ksp_type gmres
-ksp_rtol 1e-05
-ksp_atol 1e-08
-ksp_max_it 500
-ksp_gmres_restart 500
-pc_type bjacobi
-sub_pc_type ilu
-sub_pc_factor_levels 1
