# =============================================================================
# test4_ContactSedPair.opts — 2D sediment grain pair in point contact, ice-encapsulated
#
# Purpose: Study sublimation-driven ice redistribution when two sediment grains
#          touch at a single point, each enclosed in an ice shell. Inverse of
#          test3: sediment circles are tangent at the midpoint; ice encapsulates each.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test4_ContactSedPair.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type contact_sed                    # sediment grains tangent at midpoint, ice-encapsulated

# ---------- Domain ----------
-dim 2
-Nx 143
-Ny 285
-Nz 1
-Lx 1.25e-04                            # domain length in x (m)
-Ly 2.5e-04                             # domain length in y (m)
-Lz 0

# ---------- Grain Data ----------
-NCsed 2                                # number of sediment grains (tangent pair)
-RCsed 1.75e-5                          # sediment grain radius (m)
-NCice 1                                # number of ice-encapsulating shells
-RCice 3.5e-5                           # ice shell radius (m); = 2 × RCsed

# ---------- Time Stepping ----------
-delt_t 1.0e-4                          # initial time step (s)
-t_final 86400.0                        # total simulation time (s) — 1 day

# ---------- Phase-Field Physics ----------
-eps 9.3295e-07                         # diffuse interface half-width (m)
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion
-flag_sed_mode 1                        # sediment: freeze at t_sed_freeze (from universal)

# ---------- Thermal & Humidity ----------
-humidity 1.00
-temp -20.0
-grad_temp0 0.0,1.0e-03,0.0            # vertical temperature gradient (K/m)
