# =============================================================================
# test_2D_TouchingGrainPair.opts — 2D enclosed ice grain pair, tangent contact
#
# Purpose: Study sublimation and phase redistribution around a pair of sediment
#          grains enclosed in ice shells sharing a single tangent point at the
#          domain midpoint (grain_sep = 0). Standard resolution.
#          See test_2D_TouchingGrainPair_hires.opts for the hi-res version.
#          See test_1D_TouchingGrainPair.opts for the 1D cross-section.
#          See test_2D_SeparatedGrainPair.opts for the non-touching variant.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_2D_TouchingGrainPair.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type enclosed                       # ice grain enclosing two sediment grains

# ---------- Domain ----------
-dim 2
-Nx 95
-Ny 190
-Nz 1
-Lx 6.25e-05                            # domain length in x (m)
-Ly 1.25e-04                            # domain length in y (m)
-Lz 0

# ---------- Grain Radii ----------
-RCice 1.875e-5                         # ice shell outer radius — both grains (m)
-RCsed 8.75e-6                          # sediment core radius — both grains (m)
-grain_sep 0                            # grains touch at a single point (tangent)

# Per-grain overrides (uncomment to create asymmetric grains):
# -RCice0 1.2e-5                        # outer ice radius of grain 0 (m)
# -RCice1 2.5e-5                        # outer ice radius of grain 1 (m)
# -RCsed0 6.0e-6                        # sediment core radius of grain 0 (m)
# -RCsed1 6.0e-6                        # sediment core radius of grain 1 (m)

# ---------- Time Stepping ----------
-delt_t 1.0e-2                          # initial time step (s)
-t_final 86400.0                        # total simulation time (s) — debug

# ---------- Phase-Field Physics ----------
-eps 7.12e-07                           # diffuse interface half-width (m)
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 1.00
-temp -20.0
-grad_temp0 0.0,0.0,0.0
