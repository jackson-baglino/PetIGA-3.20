# =============================================================================
# test_2D_IceSlab_hires.opts — 2D ice slab with right-side sediment, high resolution
#
# Purpose: Same as test_2D_IceSlab.opts but with eps=3.56e-07 m and mesh
#          sized for 4 elements across the diffuse interface (Nx=398, Ny=80).
#          Use for convergence studies or high-fidelity 2D slab simulations.
#          See test_2D_IceSlab.opts for the standard-resolution version.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_2D_IceSlab_hires.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type ice_slab                       # circular ice blob + right-side sediment slab

# ---------- Domain ----------
-dim 2
-Nx 398
-Ny 80
-Nz 1
-Lx 1.00e-04                            # domain length in x (m)
-Ly 2.00e-05                            # domain length in y (m)
-Lz 0

# ---------- Time Stepping ----------
-delt_t 1.0e-4                          # initial time step (s)
-t_final 86400.0                        # total simulation time (s) — 1 day

# ---------- Phase-Field Physics ----------
-eps 3.56e-07                           # diffuse interface half-width (m); 4 elements/interface
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion
-t_sed_freeze 60                        # override universal 300 s: shorter freeze for this geometry

# ---------- Thermal & Humidity ----------
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0

# ---------- Penalty Override ----------
-k_sed_pen 1e9                          # sediment restoring stiffness (override universal auto)
