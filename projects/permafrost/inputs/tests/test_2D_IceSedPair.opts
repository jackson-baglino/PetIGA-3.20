# =============================================================================
# test_2D_IceSedPair.opts — 2D ice grain + sediment grain, evenly spaced
#
# Purpose: One pure circular ice grain at (Lx/2, Ly/4) and one pure circular
#          sediment grain at (Lx/2, 3*Ly/4), both of equal radius RCice.
#          No ice shell around the sediment; no sediment core inside the ice.
#          Domain: 2:1 aspect ratio (same as TouchingGrainPair tests).
#          Gap between grain surfaces ≈ Ly/2 - 2*R = 2.5e-5 m (~38 elements).
#          Wall clearance ≈ Ly/4 - R = 1.25e-5 m (~19 elements).
#          See test_1D_IceSedPair.opts for the 1D cross-section.
#          See test_2D_SingleIceGrain.opts for the single-grain variant.
#          See test_2D_TouchingGrainPair.opts for the enclosed (ice-shell) variant.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_2D_IceSedPair.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type ice_sed_pair                   # ice at (Lx/2, Ly/4), sed at (Lx/2, 3*Ly/4)

# ---------- Domain ----------
-dim 2
-Nx 95                                  # standard resolution: dx ≈ 6.58e-7 m ≈ 0.92 eps
-Ny 190
-Nz 1
-Lx 6.25e-05                            # domain length in x (m)
-Ly 1.25e-04                            # domain length in y (m); 2:1 aspect ratio
-Lz 0

# ---------- Grain Radii ----------
-RCice 1.875e-5                         # pure ice grain radius (m)
-RCsed 1.875e-5                         # pure sediment grain radius (m); equal-sized grains

# ---------- Time Stepping ----------
-delt_t 1.0e-2                          # initial time step (s)
-t_final 86400.0                        # total simulation time (s) — 100 day

# ---------- Phase-Field Physics ----------
-eps 7.12e-07                           # diffuse interface half-width (m)
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 1.00
-temp -20.0
-grad_temp0 0.0,0.0,0.0
