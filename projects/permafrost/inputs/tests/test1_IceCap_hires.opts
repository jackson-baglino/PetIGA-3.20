# =============================================================================
# test1_IceCap_hires.opts — 2D ice cap, high resolution
#
# Purpose: Same as test1_IceCap.opts but with eps=3.56e-07 m and mesh sized
#          for 4 elements across the diffuse interface (Nx=398, Ny=497).
#          See test1_IceCap.opts for the standard-resolution version.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test1_IceCap_hires.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type ice_cap                        # load ice-cap geometry from binary file

# ---------- Domain ----------
-dim 2
-dof 3                                  # override: ice / temperature / vapor (no sediment DOF)
-Nx 398
-Ny 497
-Nz 1
-Lx 1.0e-04                             # domain length in x (m)
-Ly 1.25e-04                            # domain length in y (m)
-Lz 0

# ---------- Time Stepping ----------
-delt_t 1.0e-4                          # initial time step (s)
-t_final 86400                          # total simulation time (s) — 1 day

# ---------- Phase-Field Physics ----------
-eps 3.56e-07                           # diffuse interface half-width (m); 4 elements/interface
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion
-flag_sed_mode 1                        # sediment: freeze at t_sed_freeze (from universal)

# ---------- Thermal & Humidity ----------
-humidity 1.00
-temp -20.0
-grad_temp0 0.0,1.0e-03,0.0            # vertical temperature gradient (K/m)

# ---------- Initial Condition File ----------
-initial_cond ./inputs/tests/SthavisthaInputs/AssemblePhase_reinit.dat
