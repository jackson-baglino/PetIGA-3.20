# =============================================================================
# T18 / T19: Quick 2D contact-sediment pair (smoke + IC accuracy)
# 10 steps — fast enough for smoke and IC geometry checks.
# Two sediment grains just touching, each encapsulated by an ice shell.
# rad_ice = 2 * rad_sed; grains aligned along Y.
# =============================================================================
-ic_type contact_sed

-dim 2
-dof 4
-Nx 143
-Ny 285
-Nz 1
-Lx 1.25e-04
-Ly 2.5e-04
-Lz 0

-p 2
-C 1

-NCsed 2
-RCsed 1.75e-5
-NCice 1
-RCice 3.5e-5

-delt_t 1.0e-4
-t_final 1.0e-3
-n_out 0
-outp 1
-Permafrost_output 1
-Permafrost_monitor 1

-humidity 1.00
-temp -20.0
-grad_temp0 0.0,0.0,0.0
-eps 9.3295e-07
-periodic 0
-flag_BC_Tfix 0
-flag_BC_rhovfix 0
-flag_Tdep 0
-t_sed_freeze 300
-flag_sed_mode 1

-snes_type newtonls
-snes_max_it 10
-snes_rtol 1e-06
-snes_atol 1e-08
-snes_stol 1e-06
-snes_converged_reason
-snes_linesearch_type bt
-ksp_type gmres
-ksp_rtol 1e-05
-ksp_atol 1e-08
-ksp_max_it 500
-ksp_gmres_restart 500
-ksp_converged_reason
-pc_type bjacobi
-sub_pc_type ilu
-sub_pc_factor_levels 1
