# =============================================================================
# T12: Deposition under supersaturation (hum = 1.5)
# rhov(t=0) = 1.5 * rho_vs(-20°C) → supersaturated by 50 %.
# The phase-change source S_i = α·φ_i²·φ_a²·(ρ_v − ρ_vs)/ρ_ice > 0,
# so ice should GROW (deposition).  tot_ice must increase over 200 steps.
# =============================================================================
-dim 1
-dof 4
-Nx 152
-Lx 1.00e-04
-p 2
-C 1
-delt_t 1.0e-4
-t_final 2.0e-2
-n_out 0
-outp 1
-Permafrost_output 1
-Permafrost_monitor 1
-humidity 1.5
-temp -20.0
-grad_temp0 0.0,0.0,0.0
-eps 9.3295e-07
-periodic 0
-flag_tIC 0
-flag_BC_Tfix 0
-flag_BC_rhovfix 0
-flag_Tdep 0
-snes_type newtonls
-snes_max_it 10
-snes_rtol 1e-06
-snes_atol 1e-08
-snes_stol 1e-06
-snes_converged_reason
-snes_linesearch_type bt
-ksp_type gmres
-ksp_rtol 1e-05
-ksp_atol 1e-08
-ksp_max_it 500
-ksp_gmres_restart 500
-pc_type bjacobi
-sub_pc_type ilu
-sub_pc_factor_levels 1
