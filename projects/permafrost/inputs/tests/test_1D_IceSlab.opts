# =============================================================================
# Test: 1D centered ice slab
# Purpose: Verify that a diffuse ice slab in a 1D air domain produces the
#          correct phase-field profile and that vapor/temperature fields
#          initialize consistently with temp0 and hum0.
# Expected: phi_ice peaks at 1.0 in the center [0.35 Lx, 0.65 Lx],
#           decays to 0 at boundaries; temp = -20 C uniform;
#           rhov = hum0 * rhoVS(-20).
# =============================================================================

# ---------- Domain ----------
-dim 1                                  # spatial dimension (1D)
-dof 4                                  # DOFs per node: 4 = ice / temperature / vapor / sediment
-Nx 114                                 # elements in x
-Lx 1.00e-04                            # domain length in x (m)

# ---------- Element continuity ----------
-p 2                                    # B-spline polynomial order
-C 1                                    # B-spline continuity order (C^1 for p=2, C=1)

# ---------- Time Stepping & Output ----------
-delt_t 1.0e-4                          # time step size (s)
-t_final 86400.0                        # total simulation time (s); 86400 s = 1 day
-n_out 0                                # number of output snapshots (0 = use -outp interval)
-outp 1                                 # write output every N time steps
-Permafrost_output 1                    # enable VTK field output (1=on)
-Permafrost_monitor 1                   # enable monitor table output (1=on)

# ---------- Model Parameters ----------
-humidity 0.5                          # relative humidity (fraction; <1.0 = undersaturated)
-temp -20.0                             # background temperature (°C)
-grad_temp0 0.0,0.0,0.0                # imposed temperature gradient (K/m; x,y,z); 0 = isothermal
-eps 9.3295e-07                         # diffuse interface half-width (m)
-periodic 0                             # periodic BCs (0=no, 1=yes)
-flag_sed_mode 1                        # sediment mode: -1=always 3-phase; 0=always frozen; 1=freeze at t_sed_freeze
-t_sed_freeze 900                       # simulated time (s) at which sediment evolution is frozen
-k_sed_pen -1                           # sediment penalty stiffness (-1 = auto-choose; >0 = explicit value)
-flag_avenue 1                          # residual formulation: 1=A1 (AC, no penalty); 2=A2 (AC+penalty); 3=A3 (CH)
-flag_2ph_ice 1                         # after freeze: 0=keep 3-phase ice; 1=switch to 2-phase ice formulation
-difvap_pen 1e-7                        # penalised vapour diffusivity in the air phase [m²/s]
-k_pen 1e7                              # vapour interface equilibrium stiffness
-flag_BC_Tfix 0                         # fix temperature at boundaries (0=no, 1=yes)
-flag_BC_rhovfix 0                      # fix vapor density at boundaries (0=no, 1=yes)
-flag_Tdep 0                            # temperature-dependent material properties (0=off, 1=on)

# ---------- SNES ----------
-snes_type newtonls                     # nonlinear solver: Newton with line search
-snes_max_it 10                         # max Newton iterations per time step
-snes_rtol 1e-06                        # relative residual tolerance for SNES convergence
-snes_atol 1e-08                        # absolute residual tolerance for SNES convergence
-snes_stol 1e-06                        # step tolerance for SNES convergence
-snes_converged_reason                  # print reason for SNES convergence/divergence

# ---------- Line Search ----------
-snes_linesearch_type bt                # backtracking line search (ensures residual decrease)
-snes_linesearch_monitor                # print line search progress each Newton iteration

# ---------- KSP ----------
-ksp_type gmres                         # Krylov solver: GMRES
-ksp_rtol 1e-05                         # relative residual tolerance for linear solve
-ksp_atol 1e-08                         # absolute residual tolerance for linear solve
-ksp_max_it 500                         # max GMRES iterations per linear solve
-ksp_gmres_restart 500                  # GMRES restart interval (keep full Krylov space)
-ksp_converged_reason                   # print reason for KSP convergence/divergence

# ---------- Preconditioner ----------
-pc_type bjacobi                        # block Jacobi preconditioner (one block per MPI rank)
-sub_pc_type ilu                        # ILU(k) for each block
-sub_pc_factor_levels 1                 # fill level k for ILU(k)
