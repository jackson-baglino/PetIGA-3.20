# =============================================================================
# test_1D_SingleIceGrain.opts — 1D single pure ice grain, domain-centred
#
# Purpose: Minimal test of a single ice blob in 1D air with no sediment.
#          The grain is placed at x = Lx/2 and evolves under sublimation.
#          Padding from grain edge to wall ≈ Lx/2 - RCice = 1.25e-5 m (~19 elements).
#          See test_2D_SingleIceGrain.opts for the 2D version.
#          See test_1D_IceSedPair.opts for the 1D ice+sediment variant.
#
# Usage:
#   mpiexec -np N ./permafrost \
#       -options_file inputs/universal.opts \
#       -options_file inputs/tests/test_1D_SingleIceGrain.opts
#
# Penalty and solver defaults are in inputs/universal.opts.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type single_ice                     # single ice grain centred in domain

# ---------- Domain ----------
-dim 1
-Nx 96                                  # standard resolution: dx ≈ 6.51e-7 m ≈ 0.91 eps
-Lx 6.25e-05                            # domain length (m); 4 × RCice

# ---------- Grain Radius ----------
-RCice 1.875e-5                         # ice grain radius (m)

# ---------- Time Stepping ----------
-delt_t 1.0e-2                          # initial time step (s)
-t_final 86400.0                        # total simulation time (s) — 1 day

# ---------- Phase-Field Physics ----------
-eps 7.12e-07                           # diffuse interface half-width (m)
-flag_avenue 1                          # Avenue 1: AC + penalized vapor diffusion

# ---------- Thermal & Humidity ----------
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0

# ---------- Time Stepping Override ----------
-NRmax 8
