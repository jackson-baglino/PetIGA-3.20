# =============================================================================
# Test: 2D centered ice slab (1D-equivalent)
# Purpose: Verify that the 2D ice_slab IC reproduces the 1D centered-slab
#          profile when the domain is thin in y.  The ice slab occupies
#          x in [0.35*Lx, 0.65*Lx] and the sediment slab occupies
#          x in [0.65*Lx, 0.85*Lx], both uniform across Ly.
# Expected: phi_ice peaks at 1.0 in [0.35,0.65]*Lx, phi_sed peaks at 1.0
#           in [0.65,0.85]*Lx; temp = -20 C uniform; rhov = hum0*rhoVS(-20).
#           Results should be x-invariant in y for all time.
# =============================================================================

# ---------- Initial Condition ----------
-ic_type ice_slab

# ---------- Domain ----------
-dim 2
-dof 4
-Nx 114
-Ny 23
-Nz 1
-Lx 1.00e-04
-Ly 2.00e-05
-Lz 0

# ---------- Element continuity ----------
-p 2
-C 1

# ---------- Time Stepping & Output ----------
-delt_t 1.0e-4
-t_final 86400.0
-n_out 0
-outp 1
-Permafrost_output 1
-Permafrost_monitor 1

# ---------- Model Parameters ----------
-humidity 0.95
-temp -20.0
-grad_temp0 0.0,0.0,0.0
-eps 9.3295e-07
-periodic 0
-t_sed_freeze 300
-flag_sed_mode 2
-flag_BC_Tfix 0
-flag_BC_rhovfix 0
-flag_Tdep 0

# ---------- SNES ----------
-snes_type newtonls
-snes_max_it 10
-snes_rtol 1e-06
-snes_atol 1e-08
-snes_stol 1e-06
-snes_converged_reason

# ---------- Line Search ----------
-snes_linesearch_type bt
-snes_linesearch_monitor

# ---------- KSP ----------
-ksp_type gmres
-ksp_rtol 1e-05
-ksp_atol 1e-08
-ksp_max_it 500
-ksp_gmres_restart 500
-ksp_converged_reason

# ---------- Preconditioner ----------
-pc_type bjacobi
-sub_pc_type ilu
-sub_pc_factor_levels 1
