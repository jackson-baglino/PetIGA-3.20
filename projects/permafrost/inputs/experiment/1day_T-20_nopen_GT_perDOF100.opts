# As perDOF1 but atol_T=100 (more aggressive T downweighting). Brackets the
# perDOF1 case so we can see the dt sensitivity to atol_T.
-t_final 86400.0
-t_sed_freeze 10
-temp -20.0
-humidity 1.00
-grad_temp0 0.0,0.0,0.0
-k_pen 0.0
-difvap_pen 1.0
-d0_GT 9.6e-10
-atol_T    1.0e2
-atol_ice  1.0e-8
-atol_rhov 1.0e-8
-atol_sed  1.0e-8
