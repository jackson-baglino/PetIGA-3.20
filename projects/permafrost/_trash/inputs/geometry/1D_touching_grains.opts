# =============================================================================
# geometry/1D_touching_grains.opts — 1D cross-section through two touching
# ice-shell grains (sed core enclosed). grain_sep=0 → tangent contact.
# Nx and Lx match Ny / Ly of 2D_touching_grains.opts.
# =============================================================================
-ic_type enclosed
-dim 1
-Nx 190
-Lx 1.25e-04
-RCice 1.875e-5
-RCsed 8.75e-6
-grain_sep 0
-delt_t 1.0e-2
-eps 7.12e-07
